# Copy to .env.local to override. All values below are the defaults.

# Where the .NET backend API lives (see ../backend/README.md; docs/API.md is the contract).
MERIDIAN_API_URL=http://localhost:8080

# Dev-auth identities sent as the X-User-Id header.
# Staff user for internal endpoints — u-admin (Administrator) has the full
# capability matrix so every screen loads.
MERIDIAN_API_USER=u-admin
# Portal contact for /api/portal/* endpoints — pc-1 is Karen Doyle (Redwood Pension).
MERIDIAN_PORTAL_CONTACT=pc-1

# Data source: "api" (default) fetches the backend; "mock" serves the JSON
# files in src/mocks/ exactly as before (works with the backend stopped).
DATA_SOURCE=api
